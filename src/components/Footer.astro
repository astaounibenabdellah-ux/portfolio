---
/**
 * Footer Component - Site footer with navigation and credits
 */

import { studentData } from "../data/student.ts";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <!-- Brand Section -->
      <div class="footer-section">
        <h3 class="footer-brand">{studentData.personal.firstName} {studentData.personal.lastName}</h3>
        <p class="footer-tagline">{studentData.personal.title}</p>
        <p class="footer-description">{studentData.personal.bio}</p>
      </div>

      <!-- Navigation Section -->
      <div class="footer-section">
        <h4 class="footer-section-title">Quick Links</h4>
        <ul class="footer-links">
          <li><a href="#home">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#education">Education</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>

      <!-- Social Section -->
      <div class="footer-section">
        <h4 class="footer-section-title">Connect</h4>
        <div class="footer-social">
          {
            studentData.social.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                title={social.platform}
                class="footer-social-link"
              >
                {social.platform}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} {studentData.personal.firstName} {studentData.personal.lastName}. All rights reserved.
      </p>
      <p class="footer-credits">
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> & deployed on <a
          href="https://vercel.com"
          target="_blank"
          rel="noopener noreferrer">Vercel</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    margin-top: var(--spacing-3xl);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand {
    font-size: 1.25rem;
    font-weight: 700;
    background: var(--primary-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-tagline {
    color: var(--accent-color);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .footer-description {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer-section-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    transition: color 0.3s ease;
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    color: var(--accent-color);
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-social-link {
    padding: 8px 16px;
    background: rgba(102, 126, 234, 0.1);
    border: 1px solid rgba(102, 126, 234, 0.2);
    border-radius: 6px;
    color: var(--accent-color);
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .footer-social-link:hover {
    background: var(--accent-color);
    color: var(--bg-primary);
    transform: translateY(-2px);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .footer-copyright {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-credits {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .footer-credits a {
    color: var(--accent-color);
    transition: color 0.3s ease;
  }

  .footer-credits a:hover {
    color: #764ba2;
  }

  @media (max-width: 768px) {
    .footer {
      padding: var(--spacing-2xl) 0 var(--spacing-lg);
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
    }

    .footer-bottom {
      gap: 0.5rem;
    }
  }
</style>
