---
/**
 * Skills Section Component
 * Displays technical and soft skills organized by categories
 */

import { studentData } from "../data/student";

const iconMap: Record<string, string> = {
  Brain: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z"/><path d="M8 12a4 4 0 0 1 8 0"/><circle cx="12" cy="7" r="1"/></svg>`,
  BarChart3: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17v-4"/><path d="M8 17v-2"/></svg>`,
  Code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  Globe: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`,
  Package: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
  Lightbulb: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  Users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  MessageSquare: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  BookOpen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
};
---

<section id="skills" class="skills">
  <div class="container">
    <h2 data-reveal>Skills</h2>

    {
      studentData.skills.technical.length > 0 && (
        <div class="skills-section">
          <h3 data-reveal>Technical Skills</h3>
          <div class="skills-grid">
            {studentData.skills.technical.map((skill, index) => (
              <div class="skill-card" data-reveal style={`--delay: ${index * 0.1}s`}>
                <div class="skill-header">
                  <div
                    class="skill-icon"
                    set:html={iconMap[skill.icon]}
                    title={skill.category}
                  />
                  <h4>{skill.category}</h4>
                </div>
                <div class="skill-items">
                  {skill.skills.map((item) => (
                    <span class="skill-badge">{item}</span>
                  ))}
                </div>
                <div class="skill-count">{skill.skills.length} skills</div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    {
      studentData.skills.soft && studentData.skills.soft.length > 0 && (
        <div class="skills-section">
          <h3 data-reveal style="margin-top: 4rem;">Soft Skills</h3>
          <div class="soft-skills-grid">
            {studentData.skills.soft.map((skill, index) => (
              <div class="soft-skill-card" data-reveal style={`--delay: ${index * 0.1}s`}>
                <div
                  class="soft-skill-icon"
                  set:html={iconMap[skill.icon]}
                  title={skill.name}
                />
                <h4>{skill.name}</h4>
                <p>{skill.description}</p>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .skills {
    padding: 6rem 0;
  }

  .skills-section {
    margin-top: 3rem;
  }

  .skills-section h3 {
    margin-bottom: 2rem;
    color: var(--text-primary);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .skill-card:hover {
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.3);
    transform: translateY(-4px);
  }

  .skill-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .skill-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(102, 126, 234, 0.15);
    border-radius: 8px;
    color: var(--accent-color);
    transition: all 0.3s ease;
  }

  .skill-card:hover .skill-icon {
    transform: scale(1.1);
    background: rgba(102, 126, 234, 0.25);
  }

  .skill-header h4 {
    margin: 0;
    color: var(--text-primary);
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .skill-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(102, 126, 234, 0.2);
    border-radius: 20px;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .skill-count {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .soft-skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .soft-skill-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .soft-skill-card:hover {
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.3);
    transform: translateY(-4px);
  }

  .soft-skill-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    background: rgba(102, 126, 234, 0.15);
    border-radius: 12px;
    color: var(--accent-color);
    transition: all 0.3s ease;
  }

  .soft-skill-card:hover .soft-skill-icon {
    transform: scale(1.15);
    background: rgba(102, 126, 234, 0.25);
  }

  .soft-skill-card h4 {
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .soft-skill-card p {
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .soft-skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
