---
/**
 * Contact Component - Contact information and contact form
 */

import { studentData } from "../data/student.ts";

const email = studentData.personal.email;
const location = studentData.personal.location;
---

<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-title" data-reveal>Get in Touch</h2>
    <p class="section-subtitle" data-reveal>
      Have a question or want to collaborate? Feel free to reach out!
    </p>

    <div class="contact-content">
      <!-- Contact Info -->
      <div class="contact-info" data-reveal>
        <div class="info-card">
          <div class="info-icon">✉</div>
          <h3>Email</h3>
          <a href={`mailto:${email}`} class="info-link">{email}</a>
        </div>

        <div class="info-card">
          <div class="info-icon">📍</div>
          <h3>Location</h3>
          <p class="location-text">{location}</p>
        </div>

        <div class="social-links">
          <h3>Follow Me</h3>
          <div class="social-grid">
            {
              studentData.social.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={social.platform}
                  class="social-square"
                >
                  {social.platform === "GitHub" && "GH"}
                  {social.platform === "LinkedIn" && "IN"}
                  {social.platform === "Email" && "✉"}
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <form class="contact-form" data-reveal action="https://formspree.io/f/xyzabc" method="POST">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required />
        </div>

        <div class="form-group full">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="submit-button">
          Send Message
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 2 11 13 22 2"></polyline>
            <path d="M22 2L11 13m11-11v6m0-6h-6"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: var(--spacing-3xl) 0;
    background: linear-gradient(180deg, transparent 0%, rgba(102, 126, 234, 0.05) 100%);
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .info-card:hover {
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.3);
    transform: translateY(-4px);
  }

  .info-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .info-card h3 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .info-link {
    color: var(--accent-color);
    word-break: break-all;
  }

  .location-text {
    color: var(--text-secondary);
  }

  .social-links h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .social-square {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: rgba(102, 126, 234, 0.1);
    border: 2px solid rgba(102, 126, 234, 0.2);
    border-radius: 8px;
    color: var(--accent-color);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-square:hover {
    background: var(--accent-color);
    color: var(--bg-primary);
    transform: translateY(-4px);
    border-color: var(--accent-color);
  }

  /* Contact Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }

  .form-group input,
  .form-group textarea {
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--text-primary);
    font-family: inherit;
    transition: all 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .form-group.full {
    grid-column: 1 / -1;
  }

  .submit-button {
    padding: 12px 28px;
    background: var(--primary-gradient);
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.3s ease;
    margin-top: 0.5rem;
  }

  .submit-button svg {
    width: 18px;
    height: 18px;
  }

  .submit-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(102, 126, 234, 0.3);
  }

  .submit-button:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .contact {
      padding: var(--spacing-2xl) 0;
    }

    .contact-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .section-title {
      font-size: 1.875rem;
    }

    .social-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
